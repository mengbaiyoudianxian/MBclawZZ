# MBclaw Server 环境变量配置
# 复制为 .env 并填写实际值

# LLM 配置
LLM_ENABLED=true
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# MiMo 配置（可选）
MIMO_API_KEY=
MIMO_BASE_URL=https://api.mimo.run/v1
MIMO_MODEL=mimo-code-v1

# 服务器
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# 管理面板
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# 数据库
DATABASE_URL=sqlite:///./data/mbclaw.db
